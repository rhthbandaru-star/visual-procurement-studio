# Copy to .env.local (gitignored) for local dev.
# Production builds bake VITE_SHADOWBUYER_URL via Dockerfile ARG default.

# Butterbase dashboard JSON layer (public anon access — no key required)
VITE_BUTTERBASE_API_URL=https://api.butterbase.ai/v1/app_ftjlzjm8nhdd
VITE_BUTTERBASE_ANON_KEY=anon

# ShadowBuyer FastAPI backend (override per environment).
# Empty/unreachable → frontend falls back to deterministic mock events.
VITE_SHADOWBUYER_URL=https://shadowbuyer.zeabur.app
